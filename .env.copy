# OpenOutreach .env template
#
# Copy to `.env` (chmod 600, gitignored) and fill in real values.
# Generate each secret with:
#   openssl rand -hex 32
#
# The file is consumed by `local.yml` (for local dev) and `production.yml`
# (for the Hetzner deploy). Local dev only needs API_KEY to run; production
# requires every variable below.

# ─── REST API ───────────────────────────────────────────────────────────────
# Bearer token for /api/* (CRM + MCP consumers). Required in both local and
# production. Generate with `openssl rand -hex 32`.
API_KEY=W1rmpPk1dseXh-cQo9o9lMLyLEZm2WA9K3lD3ybErb0

# ─── Webhooks (optional) ────────────────────────────────────────────────────
# WEBHOOK_URL is the POST target for message.received / message.sent /
# message.failed events. Leave blank to disable webhook delivery.
WEBHOOK_URL=http://localhost:3001/openoutreach/webhook/00000000-0000-0000-0000-000000000001
# Shared secret sent as `X-Webhook-Secret` on every webhook POST so the
# receiver can verify the caller. Generate with `openssl rand -hex 32`.
WEBHOOK_SECRET=

# ─── Proxy ──────────────────────────────────────────────────────────────────
# Global fallback proxy URL. Per-account proxies on LinkedInAccount.proxy_url
# take precedence. Leave blank for no proxy.
PROXY_URL=

# ─── LLM / OpenAI-compatible endpoint ───────────────────────────────────────
# Used by the qualifier, follow-up agent, and search-keyword generator.
# LLM_API_BASE is optional — leave blank to default to https://api.openai.com/v1.
# Any OpenAI-compatible endpoint works (OpenAI, Azure, Groq, Together, local
# llama.cpp-server, etc.) — just set LLM_API_BASE accordingly.
LLM_API_KEY=
AI_MODEL=gpt-4o-mini
LLM_API_BASE=

# ─── Production: Django ─────────────────────────────────────────────────────
# The variables below are REQUIRED in production.yml. They are unset in
# local dev, where django_settings.py falls back to safe dev defaults
# (DEBUG=True, wildcard hosts, the committed dev SECRET_KEY).

# Random secret key for Django cookie + CSRF signing. MUST differ from the
# dev default or Django crashes at import time when DJANGO_DEBUG=False.
SECRET_KEY=
# `False` in production. Leave unset or set to `True` locally.
DJANGO_DEBUG=False
# Comma-separated list of public hostnames Django will accept, e.g.
# `openoutreach.example.com`. Wildcards are allowed but discouraged.
DJANGO_ALLOWED_HOSTS=
# Comma-separated list of fully-qualified https:// origins allowed to POST
# CSRF-protected forms, e.g. `https://openoutreach.example.com`.
DJANGO_CSRF_TRUSTED_ORIGINS=

# ─── Production: Postgres ───────────────────────────────────────────────────
# Local dev keeps the hardcoded `openoutreach/openoutreach/openoutreach`
# triple in local.yml; production reads these from env and passes them
# through production.yml, so the DB password is never in Git.
POSTGRES_DB=openoutreach
POSTGRES_USER=openoutreach
POSTGRES_PASSWORD=openoutreach

# ─── Production: Caddy reverse proxy ────────────────────────────────────────
# Fully-qualified hostname for Caddy's ACME-based TLS certificate. Must have
# a DNS A record pointing at the VM's public IPv4.
CADDY_HOSTNAME=openoutreach.example.com
# Email sent to Let's Encrypt for expiry warnings.
CADDY_ACME_EMAIL=ops@example.com
# Whitespace-separated list of CIDR blocks allowed to hit /api/*. Typically
# the CRM server's IP, the MCP host's IP, and optionally one operator IP
# for curl debugging. Example: `1.2.3.4/32 5.6.7.8/32 10.0.0.0/24`
CADDY_API_ALLOWLIST=

# ─── Production: WireGuard operator VPN ─────────────────────────────────────
# Public hostname or IP where operator WG clients connect. Usually the same
# as CADDY_HOSTNAME.
WG_SERVER_URL=openoutreach.example.com
# Number of operator peers to auto-provision on first run. Start at 1 and
# increase if you add more operator devices.
WG_PEERS=3
